import std.io;
import std.main;

enum Direction {
    NORTH = 0,
    EAST,
    SOUTH,
    WEST
}

enum Color {
    RED = 1,
    GREEN = 2,
    BLUE = 3
}

int dir_to_int(int d) {
    return d;
}

main enum_test() {
    io.println("=== enum test ===");

    int d = NORTH;
    io.print("NORTH = "); io.println(d);
    io.print("EAST  = "); io.println(EAST);
    io.print("SOUTH = "); io.println(SOUTH);
    io.print("WEST  = "); io.println(WEST);

    io.print("RED   = "); io.println(RED);
    io.print("GREEN = "); io.println(GREEN);
    io.print("BLUE  = "); io.println(BLUE);

    if (EAST == 1) { io.println("EAST is 1: ok"); }
    if (BLUE == 3) { io.println("BLUE is 3: ok"); }

    int c = GREEN;
    io.print("stored GREEN = "); io.println(c);

    enum_test.errorcode = 0;
}
