// bitwise_test.slc — v0.0.3: &, |, ^, ~, <<, >>
import std.io;
import std.main;

main bitwise_test() {
    // AND
    int a = 0xFF & 0x0F;
    io.println(a);         // 15

    // OR
    int b = 0x01 | 0x10;
    io.println(b);         // 17

    // XOR
    int c = 0xFF ^ 0x0F;
    io.println(c);         // 240

    // shift left
    int d = 1 << 3;
    io.println(d);         // 8

    // shift right
    int e = 256 >> 4;
    io.println(e);         // 16

    // bitwise NOT
    int f = ~0;
    io.println(f);         // -1

    int g = ~1;
    io.println(g);         // -2

    // combined
    int flags = 0;
    flags = flags | (1 << 0);   // set bit 0
    flags = flags | (1 << 3);   // set bit 3
    io.println(flags);           // 9
    io.println(flags & (1 << 0));  // 1 (bit 0 set)
    io.println(flags & (1 << 1));  // 0 (bit 1 not set)

    bitwise_test.errorcode = 0;
}
