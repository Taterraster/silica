// ptr_cast_test.slc — v0.0.3: (type*) pointer cast syntax
import std.io;
import std.mem;
import std.main;

main ptr_cast_test() {
    // alloc a buffer, cast to int*, write and read back
    void* buf = mem.alloc(64, 0);
    int* p = (int*)buf;
    *p = 42;
    io.println(*p);   // 42

    *p = 999;
    io.println(*p);   // 999

    // void* cast back to check it's the same memory
    void* q = (void*)p;
    int* r = (int*)q;
    io.println(*r);   // 999

    ptr_cast_test.errorcode = 0;
}
